# Copy this file to ".env" and fill in at least ONE key.
# Primary provider is Claude; Groq is the automatic fallback.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# If you only have Groq right now, set this to prefer it:
# CV_PROVIDER=groq

# Optional model overrides:
# CV_MODEL=claude-sonnet-4-6              # Claude model (claude-opus-4-8 for max polish)
# GROQ_MODEL=llama-3.3-70b-versatile      # Groq model
# CV_MAX_TOKENS=8000
